.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  width: 100%;
  padding: 60rpx 0;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  text-align: center;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffffff;
}

.content {
  margin-top: 40rpx;
  width: 100%;
  padding: 0 30rpx;
}

.form-container {
  background: white;
  padding: 40rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.1);
}

.form-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  margin-bottom: 16rpx;
  color: #333;
  font-size: 28rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 16rpx;
  font-size: 32rpx;
  box-sizing: border-box;
}

.input.error {
  border-color: #f5222d;
}

.error-text {
  color: #f5222d;
  font-size: 24rpx;
  margin-top: 8rpx;
  display: block;
}

.register-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
  background-color: #1890ff;
  color: #ffffff;
  border-radius: 50rpx;
  border: none;
  margin-top: 20rpx;
}

.register-btn:active {
  background-color: #096dd9;
}

.register-btn[disabled] {
  background-color: #d9d9d9;
  color: #999;
}

.result {
  margin-top: 40rpx;
  padding: 30rpx;
  width: 90%;
  border-radius: 16rpx;
}

.success {
  color: #52c41a;
  font-size: 32rpx;
}

.error {
  color: #f5222d;
  font-size: 32rpx;
}

.result-info {
  margin-top: 20rpx;
  padding: 30rpx;
  background: #f0f5ff;
  border-radius: 16rpx;
  border: 2rpx solid #adc6ff;
  width: 90%;
}

.info-item {
  display: block;
  margin: 10rpx 0;
  color: #333;
  font-size: 28rpx;
}

.info-label {
  color: #1890ff;
  font-weight: 500;
}
