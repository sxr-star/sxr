<view class="container">
  <!-- 登录页面 -->
  <view class="login-page" wx:if="{{!isLoggedIn}}">
    <view class="header">
      <text class="title">手机号验证</text>
    </view>
    
    <view class="content">
      <view class="form-container">
        <view class="form-group">
          <text class="label">手机号</text>
          <input 
            class="input {{loginPhoneError ? 'error' : ''}}" 
            type="number" 
            placeholder="请输入手机号" 
            maxlength="11"
            value="{{loginPhone}}"
            bindinput="onLoginPhoneInput"
          />
          <text class="error-text" wx:if="{{loginPhoneError}}">{{loginPhoneError}}</text>
        </view>

        <view class="form-group">
          <text class="label">验证码</text>
          <view class="code-input-group">
            <input 
              class="input {{codeError ? 'error' : ''}}" 
              type="number" 
              placeholder="请输入验证码" 
              maxlength="4"
              value="{{code}}"
              bindinput="onCodeInput"
            />
            <button 
              class="code-btn" 
              bindtap="handleSendCode"
              disabled="{{countdown > 0 || sending}}"
            >
              {{countdown > 0 ? countdown + '秒后重试' : '发送验证码'}}
            </button>
          </view>
          <text class="error-text" wx:if="{{codeError}}">{{codeError}}</text>
        </view>

        <button 
          class="register-btn" 
          bindtap="handleLogin" 
          loading="{{loginLoading}}"
          disabled="{{loginLoading}}"
        >
          {{loginLoading ? '验证中...' : '验证并登录'}}
        </button>
      </view>
    </view>
    
    <view class="result" wx:if="{{loginResult}}">
      <text class="{{loginResult.success ? 'success' : 'error'}}">
        {{loginResult.message}}
      </text>
    </view>
  </view>

  <!-- 报到页面 -->
  <view class="register-page" wx:if="{{isLoggedIn}}">
    <view class="header">
      <text class="title">新生报到</text>
    </view>
    
    <view class="content">
      <view class="form-container">
        <view class="login-status">
          <text>已验证手机号：{{verifiedPhone}}</text>
          <text class="logout-link" bindtap="handleLogout">退出登录</text>
        </view>

        <!-- 标签切换 -->
        <view class="tab-bar">
          <view class="tab-item {{currentTab === 'register' ? 'tab-active' : ''}}" data-tab="register" bindtap="switchTab">报到登记</view>
          <view class="tab-item {{currentTab === 'status' ? 'tab-active' : ''}}" data-tab="status" bindtap="switchTab">审核状态</view>
          <view class="tab-item {{currentTab === 'dormitory' ? 'tab-active' : ''}}" data-tab="dormitory" bindtap="switchTab" wx:if="{{reviewStatus === 'approved' && dormitoryNumber}}">我的宿舍</view>
        </view>

        <!-- 报到表单 -->
        <view wx:if="{{currentTab === 'register'}}">
          <view class="form-group">
            <text class="label">姓名</text>
            <input 
              class="input {{nameError ? 'error' : ''}}" 
              type="text" 
              placeholder="请输入姓名" 
              value="{{name}}"
              bindinput="onNameInput"
            />
            <text class="error-text" wx:if="{{nameError}}">{{nameError}}</text>
          </view>

          <view class="form-group">
            <text class="label">学号</text>
            <input 
              class="input {{studentIdError ? 'error' : ''}}" 
              type="text" 
              placeholder="请输入学号" 
              value="{{studentId}}"
              bindinput="onStudentIdInput"
            />
            <text class="error-text" wx:if="{{studentIdError}}">{{studentIdError}}</text>
          </view>

          <view class="form-group">
            <text class="label">手机号</text>
            <input 
              class="input" 
              type="number" 
              value="{{phone}}"
              disabled
            />
          </view>

          <view class="form-group">
            <text class="label">身份证正面照片 <text class="label-hint">（带人像的一面）</text></text>
            <view class="photo-upload photo-upload-front" bindtap="chooseImageFront">
              <image wx:if="{{tempImagePathFront}}" class="photo-preview" src="{{tempImagePathFront}}" mode="aspectFit"/>
              <view wx:else class="photo-placeholder">
                <text class="photo-icon">+</text>
                <text class="photo-text">点击上传身份证正面照片</text>
                <text class="photo-hint">人像面：含姓名、身份证号、照片</text>
              </view>
            </view>
            <text class="error-text" wx:if="{{photoErrorFront}}">{{photoErrorFront}}</text>
          </view>

          <view class="form-group">
            <text class="label">身份证反面照片 <text class="label-hint">（带国徽的一面）</text></text>
            <view class="photo-upload photo-upload-back" bindtap="chooseImageBack">
              <image wx:if="{{tempImagePathBack}}" class="photo-preview" src="{{tempImagePathBack}}" mode="aspectFit"/>
              <view wx:else class="photo-placeholder">
                <text class="photo-icon">+</text>
                <text class="photo-text">点击上传身份证反面照片</text>
                <text class="photo-hint">国徽面：含地址、签发机关、有效期</text>
              </view>
            </view>
            <text class="error-text" wx:if="{{photoErrorBack}}">{{photoErrorBack}}</text>
          </view>

          <button 
            class="register-btn" 
            bindtap="handleRegister" 
            loading="{{loading}}"
            disabled="{{loading}}"
          >
            {{loading ? '提交中...' : '提交报到'}}
          </button>

          <view class="result" wx:if="{{result}}">
            <text class="{{result.success ? 'success' : 'error'}}">
              {{result.message}}
            </text>
          </view>

          <view class="result-info" wx:if="{{result && result.success && result.data}}">
            <text class="info-item"><text class="info-label">姓名：</text>{{result.data.name}}</text>
            <text class="info-item"><text class="info-label">学号：</text>{{result.data.student_id}}</text>
            <text class="info-item"><text class="info-label">手机号：</text>{{result.data.phone}}</text>
            <text class="info-item"><text class="info-label">报到时间：</text>{{result.data.register_time}}</text>
          </view>
        </view>

        <!-- 审核状态页面 -->
        <view wx:if="{{currentTab === 'status'}}">
          <view class="status-container">
            <view wx:if="{{statusLoading}}" class="status-loading">
              <text>加载中...</text>
            </view>
            
            <view wx:elif="{{statusError}}" class="status-error">
              <text>{{statusError}}</text>
            </view>

            <view wx:elif="{{reviewStatus}}" class="status-content">
              <view class="status-card status-{{reviewStatus}}">
                <text class="status-title">审核状态：{{reviewStatusDisplay}}</text>
              </view>
              
              <view wx:if="{{reviewStatus === 'approved'}}" class="status-detail">
                <text class="detail-item"><text class="detail-label">宿舍号：</text>{{dormitoryNumber || '待分配'}}</text>
              </view>

              <view wx:if="{{reviewStatus === 'rejected'}}" class="status-detail">
                <text class="detail-item"><text class="detail-label">驳回原因：</text>{{rejectReason || '无'}}</text>
              </view>

              <button class="refresh-btn" bindtap="fetchReviewStatus">刷新状态</button>
            </view>

            <view wx:else class="status-empty">
              <text>暂无报到记录，请先提交报到信息</text>
            </view>
          </view>
        </view>

        <!-- 宿舍管理页面 -->
        <view wx:if="{{currentTab === 'dormitory'}}">
          <view class="dormitory-container">
            <view wx:if="{{dormitoryLoading}}" class="status-loading">
              <text>加载中...</text>
            </view>
            
            <view wx:elif="{{dormitoryError}}" class="status-error">
              <text>{{dormitoryError}}</text>
            </view>

            <view wx:elif="{{dormitoryInfo}}" class="dormitory-content">
              <view class="dormitory-card">
                <text class="dormitory-title">{{dormitoryInfo.dormitory_number}}</text>
                <view class="dormitory-detail">
                  <text class="detail-row"><text class="detail-label">楼栋：</text>{{dormitoryInfo.building}}</text>
                  <text class="detail-row"><text class="detail-label">楼层：</text>{{dormitoryInfo.floor}}楼</text>
                  <text class="detail-row"><text class="detail-label">房间号：</text>{{dormitoryInfo.room_number}}</text>
                  <text class="detail-row"><text class="detail-label">容纳人数：</text>{{dormitoryInfo.capacity}}人</text>
                  <text class="detail-row"><text class="detail-label">当前入住：</text>{{dormitoryInfo.current_occupancy}}人</text>
                  <text class="detail-row"><text class="detail-label">剩余床位：</text>{{dormitoryInfo.available_beds}}个</text>
                </view>
              </view>

              <view class="roommates-section" wx:if="{{roommates.length > 0}}">
                <text class="section-title">室友信息</text>
                <view class="roommate-list">
                  <view class="roommate-item" wx:for="{{roommates}}" wx:key="student_id">
                    <text class="roommate-name">{{item.name}}</text>
                    <text class="roommate-id">学号：{{item.student_id}}</text>
                  </view>
                </view>
              </view>

              <view class="roommates-section" wx:else>
                <text class="section-title">室友信息</text>
                <text class="empty-text">暂无其他室友入住</text>
              </view>

              <button class="refresh-btn" bindtap="fetchDormitoryInfo">刷新信息</button>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>